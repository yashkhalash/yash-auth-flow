									"type": "string"
								}
							]
						},
						"method": "PUT",
						"header": [],
						"body": {
							"mode": "formdata",
							"formdata": [
								{
									"key": "fullName",
									"value": "Updated John Doe",
									"type": "text"
								},
								{
									"key": "profileImage",
									"type": "file",
									"src": []
